      "cell_type": "markdown",
      "source": [
        "## 📊 Step 3 — Data Visualization\n",
        "\n",
        "Professional HR analytics charts revealing the key salary drivers in this dataset.\n",
        "\n",
        "1. **Salary by Job Title** — which roles earn the most\n",
        "2. **Salary by Education** — ROI of higher education\n",
        "3. **Experience vs Salary** — seniority premium\n",
        "4. **Gender Pay Gap** — fairness analysis\n",
        "5. **Salary by Location** — geographic premium\n",
        "6. **Age distribution** — workforce demographics"
      ],
      "metadata": {
        "id": "WkHwK2uJYoEq"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "# ============================================================\n",
        "# CELL 4 | PROFESSIONAL HR VISUALIZATIONS\n",
        "# ============================================================\n",
        "\n",
        "fig, axes = plt.subplots(2, 3, figsize=(18, 11))\n",
        "fig.suptitle('HR Salary Analysis — Exploratory Data Analysis',\n",
        "             fontsize=18, fontweight='bold', y=1.01)\n",
        "\n",
        "# ── Plot 1: Salary by Job Title ──\n",
        "ax = axes[0, 0]\n",
        "job_sal = df.groupby('Job_Title')['Salary'].mean().sort_values(ascending=True)\n",
        "colors  = plt.cm.RdYlGn(np.linspace(0.3, 0.9, len(job_sal)))\n",
        "bars = ax.barh(job_sal.index, job_sal.values, color=colors, edgecolor='white')\n",
        "for bar, val in zip(bars, job_sal.values):\n",
        "    ax.text(val + 500, bar.get_y() + bar.get_height()/2,\n",
        "            f'${val/1000:.0f}K', va='center', fontsize=9, fontweight='bold')\n",
        "ax.set_title('Average Salary by Job Title', fontweight='bold', fontsize=12)\n",
        "ax.set_xlabel('Average Salary ($)')\n",
        "ax.xaxis.set_major_formatter(mticker.FuncFormatter(lambda x, _: f'${x/1000:.0f}K'))\n",
        "\n",
        "# ── Plot 2: Salary by Education ──\n",
        "ax = axes[0, 1]\n",
        "edu_order = ['High School', 'Bachelor', 'Master', 'PhD']\n",
        "edu_sal   = df.groupby('Education')['Salary'].mean().reindex(edu_order)\n",
        "bar_colors = ['#EF4444', '#F59E0B', '#3B82F6', '#10B981']\n",
        "bars = ax.bar(edu_sal.index, edu_sal.values, color=bar_colors, edgecolor='white', width=0.5)\n",
        "for bar, val in zip(bars, edu_sal.values):\n",
        "    ax.text(bar.get_x() + bar.get_width()/2, val + 500,\n",
        "            f'${val/1000:.0f}K', ha='center', fontsize=10, fontweight='bold')\n",
        "ax.set_title('Average Salary by Education Level', fontweight='bold', fontsize=12)\n",
        "ax.set_ylabel('Average Salary ($)')\n",
        "ax.yaxis.set_major_formatter(mticker.FuncFormatter(lambda x, _: f'${x/1000:.0f}K'))\n",
        "\n",
        "# ── Plot 3: Experience vs Salary ──\n",
        "ax = axes[0, 2]\n",
        "scatter_colors = df['Job_Title'].map({\n",
        "    j: c for j, c in zip(df['Job_Title'].unique(),\n",
        "    ['#3B82F6','#10B981','#F59E0B','#EF4444','#8B5CF6'])\n",
        "})\n",
        "ax.scatter(df['Experience'], df['Salary'], alpha=0.4, s=20,\n",
        "           c=scatter_colors, edgecolors='none')\n",
        "z = np.polyfit(df['Experience'], df['Salary'], 1)\n",
        "p = np.poly1d(z)\n",
        "x_line = np.linspace(df['Experience'].min(), df['Experience'].max(), 100)\n",
        "ax.plot(x_line, p(x_line), 'r--', linewidth=2, label='Trend')\n",
        "ax.set_title('Experience vs Salary', fontweight='bold', fontsize=12)\n",
        "ax.set_xlabel('Years of Experience')\n",
        "ax.set_ylabel('Salary ($)')\n",
        "ax.yaxis.set_major_formatter(mticker.FuncFormatter(lambda x, _: f'${x/1000:.0f}K'))\n",
        "ax.legend()\n",
        "\n",
        "# ── Plot 4: Gender Pay Gap ──\n",
        "ax = axes[1, 0]\n",
        "gender_job = df.groupby(['Job_Title', 'Gender'])['Salary'].mean().unstack()\n",
        "x = np.arange(len(gender_job.index))\n",
        "w = 0.35\n",
        "bars1 = ax.bar(x - w/2, gender_job.get('Male', 0),   w, label='Male',   color='#3B82F6', alpha=0.85)\n",
        "bars2 = ax.bar(x + w/2, gender_job.get('Female', 0), w, label='Female', color='#EC4899', alpha=0.85)\n",
        "ax.set_xticks(x)\n",
        "ax.set_xticklabels(gender_job.index, rotation=20, ha='right', fontsize=8)\n",
        "ax.set_title('Gender Pay Gap by Job Title', fontweight='bold', fontsize=12)\n",
        "ax.set_ylabel('Average Salary ($)')\n",
        "ax.yaxis.set_major_formatter(mticker.FuncFormatter(lambda x, _: f'${x/1000:.0f}K'))\n",
        "ax.legend()\n",
        "\n",
        "# ── Plot 5: Salary by Location ──\n",
        "ax = axes[1, 1]\n",
        "loc_sal = df.groupby('Location')['Salary'].mean().sort_values(ascending=False)\n",
        "loc_colors = ['#10B981', '#3B82F6', '#F59E0B']\n",
        "bars = ax.bar(loc_sal.index, loc_sal.values, color=loc_colors, edgecolor='white', width=0.4)\n",
        "for bar, val in zip(bars, loc_sal.values):\n",
        "    ax.text(bar.get_x() + bar.get_width()/2, val + 200,\n",
        "            f'${val/1000:.1f}K', ha='center', fontsize=11, fontweight='bold')\n",
        "ax.set_title('Average Salary by Location', fontweight='bold', fontsize=12)\n",
        "ax.set_ylabel('Average Salary ($)')\n",
        "ax.yaxis.set_major_formatter(mticker.FuncFormatter(lambda x, _: f'${x/1000:.0f}K'))\n",
        "\n",
        "# ── Plot 6: Salary Distribution ──\n",
        "ax = axes[1, 2]\n",
        "ax.hist(df['Salary'], bins=40, color='#6366F1', edgecolor='white', alpha=0.85)\n",
        "ax.axvline(df['Salary'].mean(),   color='red',    linestyle='--', linewidth=2, label=f\"Mean: ${df['Salary'].mean()/1000:.0f}K\")\n",
        "ax.axvline(df['Salary'].median(), color='orange', linestyle='--', linewidth=2, label=f\"Median: ${df['Salary'].median()/1000:.0f}K\")\n",
        "ax.set_title('Salary Distribution', fontweight='bold', fontsize=12)\n",
        "ax.set_xlabel('Salary ($)')\n",
        "ax.set_ylabel('Frequency')\n",
        "ax.xaxis.set_major_formatter(mticker.FuncFormatter(lambda x, _: f'${x/1000:.0f}K'))\n",
        "ax.legend()\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.savefig('hr_eda.png', dpi=150, bbox_inches='tight')\n",
        "plt.show()\n",
        "print(\"✅ Visualizations saved!\")"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/",
          "height": 764
        },
        "id": "tFB3jYwyYj8J",
        "outputId": "e5bded52-758e-4878-9a58-8876fc423a4e"
      },
      "execution_count": 4,
      "outputs": [
        {
          "output_type": "display_data",
          "data": {
            "text/plain": [
              "<Figure size 1800x1100 with 6 Axes>"
            ],
            "image/png": "\n"
          },
          "metadata": {}
        },
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "✅ Visualizations saved!\n"
          ]
        }
      ]
    },
    {
      "cell_type": "markdown",
      "source": [
        "## 🔬 Step 4 — Feature Engineering\n",
        "\n",
        "Transforming raw HR data into powerful ML features. This is the most critical step.\n",
        "\n",
        "| Feature | Type | Why It Matters |\n",
        "|---|---|---|\n",
        "| `Education_Enc` | Label encoded | ML needs numbers, not text |\n",
        "| `Job_Title_Enc` | Label encoded | Captures role hierarchy |\n",
        "| `Location_Enc` | Label encoded | Geographic salary premium |\n",
        "| `Gender_Enc` | Binary encoded | For fairness analysis |\n",
        "| `Exp_Level` | Binned | Junior/Mid/Senior/Lead tier |\n",
        "| `Exp_Squared` | Polynomial | Captures diminishing returns |\n",
        "| `Age_Group` | Binned | Career stage grouping |\n",
        "| `Role_Exp` | Interaction | Role × experience combined signal |\n",
        "\n",
        "> **Key Insight:** Interaction features (Role × Experience) are the most powerful — a Senior Director earns far more than a Junior Director with the same years of experience."
      ],
      "metadata": {
        "id": "RWZpclykYva4"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "# ============================================================\n",
        "# CELL 5 | FEATURE ENGINEERING\n",
        "# ============================================================\n",
        "\n",
        "df_ml = df.copy()\n",
        "\n",
        "# ── Label encoding ──\n",
        "le = LabelEncoder()\n",
        "for col in ['Education', 'Job_Title', 'Location', 'Gender']:\n",
        "    df_ml[f'{col}_Enc'] = le.fit_transform(df_ml[col])\n",
        "\n",
        "# ── Experience bins ──\n",
        "df_ml['Exp_Level'] = pd.cut(\n",
        "    df_ml['Experience'],\n",
        "    bins   = [0, 3, 7, 15, 50],\n",
        "    labels = [0, 1, 2, 3]   # Junior, Mid, Senior, Lead\n",
        ").astype(int)\n",
        "\n",
        "# ── Polynomial feature ──\n",
        "df_ml['Exp_Squared'] = df_ml['Experience'] ** 2\n",
        "\n",
        "# ── Age groups ──\n",
        "df_ml['Age_Group'] = pd.cut(\n",
        "    df_ml['Age'],\n",
        "    bins   = [18, 30, 40, 50, 70],\n",
        "    labels = [0, 1, 2, 3]\n",
        ").astype(int)\n",
        "\n",
        "# ── Interaction features ──\n",
        "df_ml['Role_Exp']     = df_ml['Job_Title_Enc'] * df_ml['Experience']\n",
        "df_ml['Edu_Exp']      = df_ml['Education_Enc'] * df_ml['Experience']\n",
        "df_ml['Location_Job'] = df_ml['Location_Enc']  * df_ml['Job_Title_Enc']\n",
        "\n",
        "# ── Final feature set ──\n",
        "feature_cols = [\n",
        "    'Education_Enc', 'Experience', 'Location_Enc',\n",
        "    'Job_Title_Enc', 'Age', 'Gender_Enc',\n",
        "    'Exp_Level', 'Exp_Squared', 'Age_Group',\n",
        "    'Role_Exp', 'Edu_Exp', 'Location_Job'\n",
        "]\n",
        "target_col = 'Salary'\n",
        "\n",
        "X = df_ml[feature_cols]\n",
        "y = df_ml[target_col]\n",
        "\n",
        "print(\"=\" * 55)\n",
        "print(\"🔧  FEATURE ENGINEERING COMPLETE\")\n",
        "print(\"=\" * 55)\n",
        "print(f\"✅  Total features   : {len(feature_cols)}\")\n",
        "print(f\"✅  Dataset size     : {len(X)} records\")\n",
        "print(f\"\\n📋 Feature list:\")\n",
        "for i, f in enumerate(feature_cols, 1):\n",
        "    print(f\"   {i:2}. {f}\")\n",
        "print(\"\\n📊 Sample engineered data:\")\n",
        "display(df_ml[feature_cols + [target_col]].head())"
      ],
