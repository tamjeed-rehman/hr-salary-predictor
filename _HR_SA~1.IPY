    {
      "cell_type": "markdown",
      "source": [
        "## 🧮 Step 7 — Interactive Salary Calculator\n",
        "\n",
        "Enter any employee profile and get an instant salary prediction with confidence range. This is the exact tool HR agencies use when making offer decisions."
      ],
      "metadata": {
        "id": "SDfZfHOmZGWq"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "# ============================================================\n",
        "# CELL 8 | INTERACTIVE SALARY CALCULATOR\n",
        "# ============================================================\n",
        "\n",
        "# Encoders saved during training\n",
        "edu_map      = {'High School': 0, 'Bachelor': 1, 'Master': 2, 'PhD': 3}\n",
        "job_map      = {j: i for i, j in enumerate(sorted(df['Job_Title'].unique()))}\n",
        "loc_map      = {'Rural': 0, 'Suburban': 1, 'Urban': 2}\n",
        "gender_map   = {'Female': 0, 'Male': 1}\n",
        "\n",
        "def predict_salary(education, experience, location, job_title, age, gender):\n",
        "    edu_enc = edu_map.get(education, 1)\n",
        "    job_enc = job_map.get(job_title, 0)\n",
        "    loc_enc = loc_map.get(location, 1)\n",
        "    gen_enc = gender_map.get(gender, 0)\n",
        "    exp_lvl = 0 if experience<=3 else 1 if experience<=7 else 2 if experience<=15 else 3\n",
        "\n",
        "    features = {\n",
        "        'Education_Enc' : edu_enc,\n",
        "        'Experience'    : experience,\n",
        "        'Location_Enc'  : loc_enc,\n",
        "        'Job_Title_Enc' : job_enc,\n",
        "        'Age'           : age,\n",
        "        'Gender_Enc'    : gen_enc,\n",
        "        'Exp_Level'     : exp_lvl,\n",
        "        'Exp_Squared'   : experience ** 2,\n",
        "        'Age_Group'     : 0 if age<30 else 1 if age<40 else 2 if age<50 else 3,\n",
        "        'Role_Exp'      : job_enc * experience,\n",
        "        'Edu_Exp'       : edu_enc * experience,\n",
        "        'Location_Job'  : loc_enc * job_enc\n",
        "    }\n",
        "\n",
        "    input_df    = pd.DataFrame([features])\n",
        "    prediction  = xgb.predict(input_df)[0]\n",
        "    low         = prediction * 0.90\n",
        "    high        = prediction * 1.10\n",
        "\n",
        "    return prediction, low, high\n",
        "\n",
        "def salary_calculator():\n",
        "    print(\"=\" * 55)\n",
        "    print(\"💼  HR SALARY CALCULATOR\")\n",
        "    print(\"=\" * 55)\n",
        "    print(f\"   Job titles  : {sorted(df['Job_Title'].unique())}\")\n",
        "    print(f\"   Education   : High School, Bachelor, Master, PhD\")\n",
        "    print(f\"   Location    : Urban, Suburban, Rural\")\n",
        "    print(f\"   Gender      : Male, Female\")\n",
        "    print(\"=\" * 55)\n",
        "\n",
        "    profiles = [\n",
        "        (\"PhD\",         15, \"Urban\",    \"Director\",  45, \"Male\"),\n",
        "        (\"Bachelor\",     3, \"Suburban\", \"Analyst\",   26, \"Female\"),\n",
        "        (\"Master\",       8, \"Urban\",    \"Manager\",   35, \"Male\"),\n",
        "        (\"High School\",  2, \"Rural\",    \"Analyst\",   24, \"Female\"),\n",
        "        (\"PhD\",         20, \"Urban\",    \"Director\",  50, \"Female\"),\n",
        "        (\"Master\",      12, \"Urban\",    \"Manager\",   40, \"Male\"),\n",
        "    ]\n",
        "\n",
        "    print(f\"\\n{'Profile':<35} {'Predicted':>12} {'Range':>25}\")\n",
        "    print(\"-\" * 75)\n",
        "    for edu, exp, loc, job, age, gender in profiles:\n",
        "        pred, low, high = predict_salary(edu, exp, loc, job, age, gender)\n",
        "        profile = f\"{job} | {edu} | {exp}yr | {loc} | {gender}\"\n",
        "        print(f\"{profile:<35} ${pred:>10,.0f}   ${low:,.0f} – ${high:,.0f}\")\n",
        "\n",
        "salary_calculator()"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "Zyn3UQ-OZCd5",
        "outputId": "9cc365e3-dc47-48cf-8a86-aa688d457a63"
      },
      "execution_count": 8,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "=======================================================\n",
            "💼  HR SALARY CALCULATOR\n",
            "=======================================================\n",
            "   Job titles  : ['Analyst', 'Director', 'Engineer', 'Manager']\n",
            "   Education   : High School, Bachelor, Master, PhD\n",
            "   Location    : Urban, Suburban, Rural\n",
            "   Gender      : Male, Female\n",
            "=======================================================\n",
            "\n",
            "Profile                                Predicted                     Range\n",
            "---------------------------------------------------------------------------\n",
            "Director | PhD | 15yr | Urban | Male $   150,991   $135,892 – $166,090\n",
            "Analyst | Bachelor | 3yr | Suburban | Female $    57,392   $51,653 – $63,131\n",
            "Manager | Master | 8yr | Urban | Male $   118,819   $106,937 – $130,701\n",
